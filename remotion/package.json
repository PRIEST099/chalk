{
  "name": "remotion",
  "version": "1.0.0",
  "description": "Official Chalk demo video, built with Remotion.",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.490",
    "@remotion/fonts": "4.0.490",
    "@remotion/media-parser": "4.0.490",
    "@remotion/transitions": "4.0.490",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.490"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.490",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "prepare-media": "node scripts/generate-media-manifest.mjs",
    "studio": "npm run prepare-media && remotion studio",
    "render": "npm run prepare-media && remotion render ChalkDemo out/chalk-demo.mp4 --codec=h264 --pixel-format=yuv420p",
    "dev": "npm run prepare-media && remotion studio",
    "build": "remotion bundle",
    "typecheck": "tsc",
    "upgrade": "remotion upgrade",
    "lint": "eslint src"
  },
  "sideEffects": [
    "*.css"
  ]
}
